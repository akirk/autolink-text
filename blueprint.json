{
  "landingPage": "/wp-admin/post-new.php",
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "gutenberg"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "git:directory",
        "url": "https://github.com/akirk/auto-linker",
        "ref": "dist/main"
      },
      "options": {
        "activate": true,
        "targetFolderName": "auto-linker"
      },
      "progress": {
        "caption": "Installing plugin from GitHub: akirk/auto-linker"
      }
    },
    {
      "step": "defineWpConfigConsts",
      "consts": {
        "WP_ALLOW_COLLABORATION": true
      }
    },
    {
      "step": "runPHP",
      "code": "<?php require_once '/wordpress/wp-load.php'; $data = array( 'user_login' => 'auto-linker', 'user_pass' => 'password', 'role' => 'administrator', 'display_name' => 'Auto Linker',); wp_insert_user( $data ); ?>",
      "progress": {
        "caption": "createUser: auto-linker"
      }
    },
    {
      "step": "setSiteOptions",
      "options": {
        "auto_linker_bot_user_id": "2",
        "auto_linker_terms": [
          {
            "term": "Playground",
            "url": "https://playground.wordpress.net/"
          }
        ]
      }
    }
  ],
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "meta": {
    "title": "Auto Linker",
    "author": "https://github.com/akirk/playground-step-library"
  }
}
